#!/bin/bash
# Pre-commit hook: validate before committing
# Bypass with: git commit --no-verify

set -e

echo "=== Pre-commit checks (11) ==="
echo ""

# 1. Ruff linter
echo "[1/11] Running ruff linter..."
if command -v ruff &> /dev/null; then
    ruff check tools/
    echo "      ✓ Lint passed"
else
    echo "      ⚠ ruff not installed, skipping (pip install ruff)"
fi
echo ""

# 2. JSON/YAML validation
echo "[2/11] Validating JSON/YAML configs..."
python3 -c "
import json
import sys

try:
    import yaml
    has_yaml = True
except ImportError:
    has_yaml = False
    print('      ⚠ pyyaml not installed, skipping YAML check')

# Validate plugin.json
try:
    with open('.codex-plugin/plugin.json') as f:
        json.load(f)
except Exception as e:
    print(f'      ✗ plugin.json invalid: {e}')
    sys.exit(1)

# Validate Codex marketplace.json
try:
    with open('.agents/plugins/marketplace.json') as f:
        json.load(f)
except Exception as e:
    print(f'      ✗ marketplace.json invalid: {e}')
    sys.exit(1)

# Validate config.example.yaml
if has_yaml:
    try:
        with open('config/config.example.yaml') as f:
            yaml.safe_load(f)
    except Exception as e:
        print(f'      ✗ config.example.yaml invalid: {e}')
        sys.exit(1)

print('      ✓ Config files valid')
"
echo ""

# 3. AGENTS.md size check (characters, not bytes - better approximates tokens)
echo "[3/11] Checking AGENTS.md size..."
MAX_CHARS=40000  # 40K characters
AGENTS_CHARS=$(wc -m < AGENTS.md 2>/dev/null || echo 0)
if [ "$AGENTS_CHARS" -gt "$MAX_CHARS" ]; then
    SIZE_K=$(echo "scale=1; $AGENTS_CHARS / 1000" | bc)
    echo "      ✗ AGENTS.md is ${SIZE_K}K chars (max 40.0K)"
    exit 1
else
    SIZE_K=$(echo "scale=1; $AGENTS_CHARS / 1000" | bc)
    echo "      ✓ AGENTS.md is ${SIZE_K}K chars (max 40.0K)"
fi
echo ""

# 4. Codex plugin metadata check
echo "[4/11] Checking Codex plugin metadata..."
python3 -c "
import json
import sys
import re

with open('.codex-plugin/plugin.json') as f:
    plugin = json.load(f)

with open('.agents/plugins/marketplace.json') as f:
    marketplace = json.load(f)

plugin_name = plugin.get('name')
plugin_version = plugin.get('version', '')
entries = marketplace.get('plugins', [])

if plugin_name != 'maxinger15-music':
    print(f'      ✗ Unexpected plugin name: {plugin_name}')
    sys.exit(1)
if not re.match(r'^\d+\.\d+\.\d+(-[0-9A-Za-z.-]+)?$', plugin_version):
    print(f'      ✗ Invalid plugin version: {plugin_version}')
    sys.exit(1)
if not any(entry.get('name') == plugin_name for entry in entries):
    print('      ✗ Marketplace missing maxinger15-music entry')
    sys.exit(1)

print(f'      ✓ Codex plugin metadata valid ({plugin_version})')
"
echo ""

# 5. Skill frontmatter validation
echo "[5/11] Validating skill frontmatter..."
python3 -c "
import os
import sys
import re

try:
    import yaml
except ImportError:
    print('      ⚠ pyyaml not installed, skipping')
    sys.exit(0)

REQUIRED_FIELDS = ['name', 'description']
LEGACY_FIELDS = {'model', 'effort', 'allowed-tools', 'argument-hint', 'context'}
VALID_COMPLEXITY_TIERS = {'opus', 'sonnet', 'haiku'}
VALID_EFFORT = {'low', 'medium', 'high', 'xhigh', 'max'}

errors = []
skill_count = 0

for skill_dir in os.listdir('skills'):
    skill_path = f'skills/{skill_dir}/SKILL.md'
    if not os.path.isdir(f'skills/{skill_dir}') or not os.path.exists(skill_path):
        continue

    skill_count += 1
    with open(skill_path, 'r') as f:
        content = f.read()

    match = re.match(r'^---\n(.*?)\n---', content, re.DOTALL)
    if not match:
        errors.append(f'{skill_dir}: missing frontmatter')
        continue

    try:
        fm = yaml.safe_load(match.group(1))
    except yaml.YAMLError as e:
        errors.append(f'{skill_dir}: invalid YAML')
        continue

    for field in REQUIRED_FIELDS:
        if field not in fm:
            errors.append(f'{skill_dir}: missing \"{field}\"')

    legacy_present = LEGACY_FIELDS & set(fm)
    if legacy_present:
        errors.append(f'{skill_dir}: legacy frontmatter fields {sorted(legacy_present)}')

    openai_yaml = f'skills/{skill_dir}/agents/openai.yaml'
    if not os.path.exists(openai_yaml):
        errors.append(f'{skill_dir}: missing agents/openai.yaml')

with open('skills/metadata.yaml') as f:
    metadata = yaml.safe_load(f) or {}
skill_metadata = metadata.get('skills', {})
if set(skill_metadata) != {
    d for d in os.listdir('skills')
    if os.path.isdir(f'skills/{d}') and os.path.exists(f'skills/{d}/SKILL.md')
}:
    errors.append('skills/metadata.yaml does not match on-disk skills')

for skill_name, meta in skill_metadata.items():
    tier = meta.get('complexity_tier')
    effort = meta.get('complexity_effort')
    if tier not in VALID_COMPLEXITY_TIERS:
        errors.append(f'{skill_name}: invalid complexity_tier \"{tier}\"')
    if effort is not None and effort not in VALID_EFFORT:
        errors.append(f'{skill_name}: invalid complexity_effort \"{effort}\"')

if errors:
    print('      ✗ Frontmatter errors:')
    for e in errors:
        print(f'        - {e}')
    sys.exit(1)

print(f'      ✓ All {skill_count} skills have valid frontmatter')
"
echo ""

# 6. CHANGELOG format check
echo "[6/11] Checking CHANGELOG format..."
if [ -f "CHANGELOG.md" ]; then
    if grep -q "\[Unreleased\]" CHANGELOG.md; then
        echo "      ✓ CHANGELOG has [Unreleased] section"
    else
        echo "      ✗ CHANGELOG.md missing [Unreleased] section"
        echo "      Add '## [Unreleased]' section at top of changelog"
        exit 1
    fi
else
    echo "      ⚠ CHANGELOG.md not found, skipping"
fi
echo ""

# 7. Merge conflict markers check
echo "[7/11] Checking for merge conflict markers..."
CONFLICT_FILES=$(git diff --cached --name-only | xargs grep -l "^<<<<<<< \|^=======$\|^>>>>>>> " 2>/dev/null || true)
if [ -n "$CONFLICT_FILES" ]; then
    echo "      ✗ Merge conflict markers found in:"
    echo "$CONFLICT_FILES" | while read -r file; do
        echo "        - $file"
    done
    exit 1
else
    echo "      ✓ No merge conflict markers"
fi
echo ""

# 8. Large file check
echo "[8/11] Checking for large files..."
MAX_SIZE=600000  # 600KB
LARGE_FILES=""
for file in $(git diff --cached --name-only); do
    if [ -f "$file" ]; then
        size=$(wc -c < "$file" 2>/dev/null || echo 0)
        if [ "$size" -gt "$MAX_SIZE" ]; then
            size_kb=$((size / 1024))
            LARGE_FILES="$LARGE_FILES\n        - $file (${size_kb}KB)"
        fi
    fi
done
if [ -n "$LARGE_FILES" ]; then
    echo "      ✗ Large files (>600KB) found:"
    echo -e "$LARGE_FILES"
    echo "      Use .gitignore or git-lfs for large files"
    exit 1
else
    echo "      ✓ No large files"
fi
echo ""

# 9. Security scan (bandit + pip-audit)
echo "[9/11] Running security scan..."

# Check code with bandit
if command -v bandit &> /dev/null; then
    # -r recursive, -ll medium+ severity, -q quiet, -s B108 skip hardcoded /tmp
    if ! bandit -r tools/ -ll -q -s B108 2>/dev/null; then
        echo "      ✗ Security issues found in code"
        echo "      Run 'bandit -r tools/ -ll -s B108' for details"
        exit 1
    fi
else
    echo "      ⚠ bandit not installed, skipping code scan (pip install bandit)"
fi

# Check dependencies with pip-audit
if command -v pip-audit &> /dev/null; then
    if [ -f "requirements.txt" ]; then
        # Run pip-audit and capture output
        AUDIT_OUTPUT=$(pip-audit -r requirements.txt 2>&1)
        AUDIT_EXIT=$?

        if [ $AUDIT_EXIT -eq 0 ]; then
            echo "      ✓ Security scan passed"
        else
            echo "      ✗ Known vulnerabilities in dependencies"
            echo "$AUDIT_OUTPUT" | grep -E "Name|Version|ID|Fix"
            echo "      Run 'pip-audit -r requirements.txt' for full details"
            exit 1
        fi
    else
        echo "      ✓ Security scan passed (no requirements.txt)"
    fi
else
    echo "      ⚠ pip-audit not installed, skipping dependency scan (pip install pip-audit)"
fi
echo ""

# 10. All tests (plugin + unit)
echo "[10/11] Running tests..."
if command -v pytest &> /dev/null || python3 -c "import pytest" 2>/dev/null; then
    if python3 -m pytest tests/ -q --tb=line 2>/dev/null; then
        echo "      ✓ Tests passed"
    else
        echo "      ✗ Tests failed"
        echo "      Run 'python3 -m pytest tests/ -v' for details"
        exit 1
    fi
else
    echo "      ⚠ pytest not installed, skipping (pip install pytest)"
fi
echo ""

# 11. Test count badge sync
echo "[11/11] Checking test count badge..."
if command -v pytest &> /dev/null || python3 -c "import pytest" 2>/dev/null; then
    ACTUAL_COUNT=$(python3 -m pytest tests/ --co -q 2>/dev/null | tail -1 | grep -oP '^\d+')
    BADGE_COUNT=$(grep -oP 'badge/tests-\K\d+' README.md 2>/dev/null)

    if [ -z "$ACTUAL_COUNT" ] || [ -z "$BADGE_COUNT" ]; then
        echo "      ⚠ Could not determine test count or badge, skipping"
    elif [ "$ACTUAL_COUNT" != "$BADGE_COUNT" ]; then
        echo "      ✗ Test badge out of date!"
        echo "        README badge: $BADGE_COUNT tests"
        echo "        Actual count: $ACTUAL_COUNT tests"
        echo "        Update: ![Tests](https://img.shields.io/badge/tests-${ACTUAL_COUNT}-brightgreen)"
        exit 1
    else
        echo "      ✓ Test badge matches ($ACTUAL_COUNT)"
    fi
else
    echo "      ⚠ pytest not installed, skipping"
fi
echo ""

echo "=== All checks passed ==="
